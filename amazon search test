import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.testng.Assert;
import org.testng.annotations.*;

import java.time.Duration;
import java.util.List;

public class AmazonTest {

    WebDriver driver;
    WebDriverWait wait;

    @BeforeMethod
    public void setup() {
        driver = new ChromeDriver();
        wait = new WebDriverWait(driver, Duration.ofSeconds(20));
        driver.get("https://www.amazon.com");
    }

    @Test
    public void searchProductTest() {

        WebElement searchBox = wait.until(
                ExpectedConditions.elementToBeClickable(By.id("twotabsearchtextbox"))
        );

        searchBox.sendKeys("iphone 13");
        searchBox.submit();

        List<WebElement> results = wait.until(
                ExpectedConditions.presenceOfAllElementsLocatedBy(
                        By.cssSelector("div[data-component-type='s-search-result']")
                )
        );

        Assert.assertFalse(results.isEmpty(), "Arama sonucu bulunamadı");

        WebElement firstProduct = results.get(1);
        firstProduct.click();

        WebElement productTitle = wait.until(
                ExpectedConditions.presenceOfElementLocated(By.id("productTitle"))
        );

        String titleText = productTitle.getText();

        Assert.assertFalse(titleText.isEmpty(), "Ürün başlığı boş!");
    }

    @AfterMethod
    public void teardown() {
        driver.quit();
    }
}
