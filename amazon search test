import org.openqa.selenium.*;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.support.ui.*;
import org.testng.Assert;
import org.testng.annotations.*;

import java.time.Duration;
import java.util.List;

public class tesst3 {

    WebDriver driver;
    WebDriverWait wait;

    @BeforeMethod
    public void setup() {

        ChromeOptions options = new ChromeOptions();

        // 🔥 BOT detection kırıcı ayarlar
        options.addArguments("--disable-blink-features=AutomationControlled");
        options.addArguments("--start-maximized");
        options.addArguments("--disable-infobars");
        options.addArguments("--disable-extensions");

        driver = new ChromeDriver(options);
        wait = new WebDriverWait(driver, Duration.ofSeconds(30));

        driver.get("https://www.amazon.com.tr");

        // Cookie accept
        try {
            wait.until(ExpectedConditions.elementToBeClickable(By.id("sp-cc-accept"))).click();
        } catch (Exception ignored) {}

        // 🔥 CAPTCHA check
        if (driver.getPageSource().toLowerCase().contains("captcha")) {
            throw new RuntimeException("❌ CAPTCHA çıktı → test durduruldu");
        }
    }

    @Test
    public void searchProductTest() throws InterruptedException {

        // Search
        WebElement searchBox = wait.until(
                ExpectedConditions.elementToBeClickable(By.id("twotabsearchtextbox"))
        );

        searchBox.sendKeys("iphone 13");
        searchBox.submit();

        // 🔥 Amazon lazy load için küçük bekleme
        Thread.sleep(2000);

        // Scroll yap (ürünleri yükletmek için)
        ((JavascriptExecutor) driver).executeScript(
                "window.scrollBy(0, 800);"
        );

        // 🔥 EN SAĞLAM locator (Amazon TR için)
        List<WebElement> products = wait.until(
                ExpectedConditions.presenceOfAllElementsLocatedBy(
                        By.xpath("//div[@data-component-type='s-search-result']//h2//a")
                )
        );

        System.out.println("Bulunan ürün sayısı: " + products.size());

        Assert.assertTrue(products.size() > 0, "Ürün listesi boş!");

        WebElement firstProduct = null;

        for (WebElement product : products) {
            try {
                if (product.isDisplayed() && product.getAttribute("href") != null) {
                    firstProduct = product;
                    break;
                }
            } catch (StaleElementReferenceException ignored) {}
        }

        Assert.assertNotNull(firstProduct, "Tıklanabilir ürün bulunamadı!");

        // Scroll
        ((JavascriptExecutor) driver).executeScript(
                "arguments[0].scrollIntoView({block:'center'});", firstProduct
        );

        // Click
        try {
            wait.until(ExpectedConditions.elementToBeClickable(firstProduct)).click();
        } catch (Exception e) {
            System.out.println("JS click devreye girdi");
            ((JavascriptExecutor) driver).executeScript(
                    "arguments[0].click();", firstProduct
            );
        }

        // Ürün sayfası
        WebElement productTitle = wait.until(
                ExpectedConditions.visibilityOfElementLocated(By.id("productTitle"))
        );

        String title = productTitle.getText();

        System.out.println("Ürün: " + title);

        Assert.assertFalse(title.isEmpty(), "Ürün başlığı boş!");
    }

    @AfterMethod
    public void teardown() {
        if (driver != null) {
            driver.quit();
        }
    }
}
