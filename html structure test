import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class tesst2 {


    public void main (String[] args) {



        WebDriver driver = new ChromeDriver();
        driver.get("https:\\www.amazon.com");
        String pageSource = driver.getPageSource();

        if (pageSource.contains("stylesheet")) {
            System.out.println("Bu sayfa stylesheet içeriyor");
        }  if (!pageSource.contains("stylesheet")) {
            System.out.println("Stylesheet bağlantısı  bulunamadı harici css veya tailwind kullanıyo olabilir");
        }
        if (pageSource.contains("script")) {
            System.out.println("Bu sayfada harici java vardır");
        } if (!pageSource.contains("script")) {
            System.out.println("harici java bulunamadı ");
        }
        if (!pageSource.contains("stylesheet") && !pageSource.contains("style")) {
            System.out.println("Bu sayfa tailwind içeriyor");
        }
        if (!pageSource.contains("stylesheet") && !pageSource.contains("style")) {
            System.out.println("CSS bulunamadı");
        }
        if (pageSource.contains("<!--")) {
            System.out.println("yorum satırı içeriyor");
        }   if (!pageSource.contains("<!--")){
            System.out.println("yorum satırı içermiyor");
        }



    }
}
