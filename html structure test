import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.Assert;
import org.testng.annotations.*;

public class PageSourceTest {

    WebDriver driver;

    @BeforeMethod
    public void setup() {
        driver = new ChromeDriver();
        driver.get("https://www.amazon.com");
    }

    @Test
    public void checkPageSourceTest() {

        String pageSource = driver.getPageSource();

        // CSS kontrol
        boolean hasCSS = pageSource.contains("stylesheet") || pageSource.contains("<style>");
        Assert.assertTrue(hasCSS, "Sayfada CSS bulunamadı!");

        // JS kontrol
        boolean hasJS = pageSource.contains("<script");
        Assert.assertTrue(hasJS, "Sayfada JS bulunamadı!");

        // Yorum satırı kontrol
        boolean hasComment = pageSource.contains("<!--");
        Assert.assertTrue(hasComment, "Yorum satırı bulunamadı!");

    }

    @AfterMethod
    public void teardown() {
        driver.quit();
    }
}
