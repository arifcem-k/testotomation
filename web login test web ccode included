//////////////////////////////////HTML PART/////////////////////////////////////////////
<!doctype html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>Fateless | Yönetici Girişi</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css?family=Poppins:300,500,700&display=swap" rel="stylesheet">

<style>
*{
  box-sizing:border-box;
  margin:0;
  padding:0;
}

body{
  background-color:#1C2127;
  font-family:'Poppins', sans-serif;
  height:100vh;
  display:flex;
  flex-direction:column;
  color:white;
}

/* WRAPPER */

.wrapper{
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:100px;
  max-width:1200px;
  width:90%;
  margin:auto;
}

/* LOGIN AREA */

.login-area{
  width:350px;
}

.login-area h1{
  font-size:32px;
  margin-bottom:10px;
}

.login-area p{
  font-size:14px;
  opacity:0.7;
  margin-bottom:30px;
}

.input-group{
  margin-bottom:20px;
}

.input-group label{
  font-size:13px;
  display:block;
  margin-bottom:6px;
  opacity:0.8;
}

.input-group input{
  width:100%;
  padding:12px 14px;
  border-radius:8px;
  border:1px solid rgba(255,255,255,0.1);
  background:rgba(255,255,255,0.05);
  color:white;
  font-size:14px;
  outline:none;
  transition:0.3s;
}

.input-group input:focus{
  border:1px solid #8594A5;
  background:rgba(255,255,255,0.08);
}

.login-btn{
  width:100%;
  padding:12px;
  border:none;
  border-radius:8px;
  background:#8594A5;
  color:#1C2127;
  font-weight:600;
  cursor:pointer;
  transition:0.3s;
}

.login-btn:hover{
  background:#A0AEC0;
}

/* DOOR */

.door-frame{
  height:450px;
  width:260px;
  border-radius:90px 90px 0 0;
  background-color:#8594A5;
  display:flex;
  justify-content:center;
  align-items:center;
}

.door{
  height:410px;
  width:220px;
  border-radius:70px 70px 0 0;
  background-color:#A0AEC0;
  position:relative;
}

.nameplate{
  position:absolute;
  top:135px;
  left:50%;
  transform:translateX(-50%);
  width:100px;
  height:40px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:11px;
  font-weight:600;
  letter-spacing:3px;
  color:#1C2127;
  background:linear-gradient(145deg,#dfe6ee,#b8c4d2);
  border-radius:6px;
}

/* FOOTER */

footer{
  padding:12px 10px;
  text-align:center;
  background:rgba(255,255,255,0.04);
  border-top:1px solid rgba(255,255,255,0.1);
}

footer p{
  font-size:14px;
  font-weight:300;
  color:rgba(255,255,255,0.6);
}

/* MOBILE */

@media(max-width:900px){
  .wrapper{
    flex-direction:column;
    gap:50px;
  }
}
</style>
</head>

<body>

<div class="wrapper">

  <div class="login-area">
    <h1>Yönetici Girişi</h1>
    <p>Fateless Studio paneline erişmek için giriş yapın.</p>

    <form id="loginForm">
      <div class="input-group">
        <label>E-posta</label>
        <input id="email" type="email" placeholder="admin@fateless.com.tr" required>
      </div>

      <div class="input-group">
        <label>Şifre</label>
        <input id="password" type="password" placeholder="123456" required>
      </div>

      <button id="loginBtn" type="submit" class="login-btn">Giriş Yap</button>
    </form>
  </div>

  <div class="door-frame">
    <div class="door">
      <div class="nameplate">FATELESS</div>
    </div>
  </div>

</div>

<footer>
  <p>
     Fateless Studio — aklınızda olan sorular için.<br>
     info@fateless.com.tr
  </p>
</footer>

<script>


const correctEmail = "admin@fateless.com.tr";
const correctPassword = "123456";

const form = document.getElementById("loginForm");

form.addEventListener("submit", function(event){
  event.preventDefault(); 

  const email = document.getElementById("email").value;
  const password = document.getElementById("password").value;

  if(email === correctEmail && password === correctPassword){
    alert("Giriş Başarılı ✅");
  } else {
    alert("Giriş Başarısız ❌");
  }
});

</script>

</body>
</html>

